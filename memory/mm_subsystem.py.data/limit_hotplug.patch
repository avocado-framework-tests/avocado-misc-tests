+	max_blocks = (total_count / process_every);
+	if (max_blocks < 10) max_blocks = 10;
+	if (max_blocks > 100) max_blocks = 100;
+	printf("- processing %d of %d memory blocks (10%%)\n", max_blocks, total_count);
+	rewinddir(dir);
+
