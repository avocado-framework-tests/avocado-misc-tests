 		return 1;
 
+	/* First pass: count total memory blocks */
+	while ((memory = readdir(dir))) {
+		if (!strcmp(memory->d_name, ".") ||
+		    !strcmp(memory->d_name, "..") ||
+		    memory->d_type != DT_DIR ||
+		    strncmp(memory->d_name, "memory", 6))
